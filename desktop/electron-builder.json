{
  "appId": "com.cnx.orderrobot",
  "productName": "OrderRobot",
  "directories": {
    "output": "dist/desktop/installer"
  },
  "files": [
    "desktop/**/*",
    "scripts/bridge-server.mjs",
    "apps/kiosk-ui/dist/**/*",
    "data/**/*",
    ".env.example",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "dist/desktop/backends/OrderRobotCoreBackend",
      "to": "backends/OrderRobotCoreBackend"
    },
    {
      "from": "dist/desktop/backends/OrderRobotAiBackend",
      "to": "backends/OrderRobotAiBackend"
    }
  ],
  "asar": true,
  "artifactName": "OrderRobot-Setup-${version}.${ext}",
  "win": {
    "icon": "desktop/assets/orderrobot.ico",
    "signAndEditExecutable": false,
    "forceCodeSigning": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerIcon": "desktop/assets/orderrobot.ico",
    "uninstallerIcon": "desktop/assets/orderrobot.ico",
    "installerHeaderIcon": "desktop/assets/orderrobot.ico",
    "shortcutName": "OrderRobot"
  }
}
