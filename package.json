{
  "name": "order-robot-demo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "install:ui": "npm --prefix apps/kiosk-ui install",
    "install:python": "python -m pip install -r services/core-backend/requirements.txt -r services/ai-backend/requirements.txt",
    "install:all": "npm run install:ui && npm run install:python",
    "install:bridge": "npm --prefix mau/Ay-bi-ai install",
    "dev:ui": "npm --prefix apps/kiosk-ui run dev",
    "dev:core": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-core.ps1",
    "dev:ai": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-ai.ps1",
    "dev:bridge": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-bridge.ps1",
    "dev:bridge:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-bridge.ps1 -ForceRestart",
    "dev": "concurrently --kill-others-on-fail \"npm:dev:bridge:dev\" \"npm:dev:core\" \"npm:dev:ai\" \"npm:dev:ui\"",
    "test:core": "powershell -NoProfile -Command \"Set-Location 'services/core-backend'; python -m pytest tests\"",
    "test:ai": "powershell -NoProfile -Command \"Set-Location 'services/ai-backend'; python -m pytest tests\"",
    "test:python": "npm run test:core && npm run test:ai",
    "build": "npm run build:ui",
    "build:ui": "npm --prefix apps/kiosk-ui run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
